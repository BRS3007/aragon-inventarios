{
  "name": "loginyregister",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "@tailwindcss/cli": "^4.2.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.16.1",
    "nodemailer": "^7.0.13",
    "path": "^0.12.7",
    "sweetalert2": "^11.26.20",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.2"
  },
  "scripts": {
    "start": "node server.js",
    "build": "npm install @tailwindcss/oxide-linux-x64-gnu && npx @tailwindcss/cli -i ./src/input.css -o ./dist/output.css",
    "server": "node server.js",
    "tailwind": "npx @tailwindcss/cli -i ./src/input.css -o ./dist/output.css --watch",
    "dev": "concurrently \"npm run server\" \"npm run tailwind\""
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
