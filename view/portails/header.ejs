<header class="bg-white shadow-md p-4">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
    
    <div class="flex items-center gap-3">
      <img src="/img/logo.png" alt="Aragon Logo" class="h-12 w-auto">
      <h1 class="hidden md:block font-bold text-xl text-gray-800">ARAGON</h1>
    </div>

    <div class="text-center">
      <p class="text-sm md:text-base font-medium text-gray-600" id="live-clock"></p>
    </div>

    <div class="flex items-center gap-4">
      <div id="language-selector">
        </div>
      
      <a href="/logout" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg text-sm font-bold transition-all shadow-sm">
        Cerrar Sesión
      </a>
    </div>

  </div>
</header>

<script>
  function updateClock() {
    const now = new Date();
    const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' };
    const clockElement = document.getElementById('live-clock');
    if (clockElement) {
        clockElement.innerText = now.toLocaleDateString('es-ES', options);
    }
  }
  setInterval(updateClock, 1000);
  updateClock();
</script>