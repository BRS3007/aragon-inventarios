<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title data-i18n="titulo.ingreso">Ingreso de Productos - ARAGON</title>

    <link rel="icon" type="image/png" href="favicons/android-chrome-192x192.png"> 
    <link rel="apple-touch-icon" sizes="180x180" href="favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="favicons/favicon-16x16.png">
    
    <link rel="stylesheet" href="css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous">

    <style>
        /* CSS BLINDADO PARA COINCIDIR CON LAS OTRAS PANTALLAS */
        .main-header {
            display: flex !important;
            justify-content: space-between !important;
            align-items: center !important;
            padding: 10px 20px !important;
            background-color: #ffffff !important;
            border-bottom: 1px solid #e5e7eb !important;
            height: 90px !important;
        }
        .logo-img { height: 75px !important; width: auto !important; }
        
        .centered-clock {
            display: flex !important;
            flex-direction: column !important;
            align-items: center !important;
            justify-content: center !important;
            background-color: #f9fafb !important;
            padding: 5px 15px !important;
            border-radius: 6px !important;
            border: 1px solid #e5e7eb !important;
            height: 65px !important; 
        }
        #reloj-fecha { font-size: 13px !important; color: #4b5563 !important; }
        #reloj-hora { font-size: 14px !important; font-weight: bold !important; color: #dc2626 !important; }

        .logout-btn {
            display: inline-block !important;
            background-color: #dc2626 !important;
            color: #ffffff !important;
            padding: 10px 20px !important;
            border-radius: 6px !important;
            font-weight: bold !important;
            text-decoration: none !important;
            font-size: 14px !important;
        }

        .user-info-bar {
            display: flex !important;
            justify-content: space-between !important;
            align-items: center !important;
            background-color: #f9fafb !important;
            border-bottom: 1px solid #e5e7eb !important;
            padding: 0 20px !important;
            height: 50px !important;
        }
        .nav-main-horizontal {
            display: flex !important;
            gap: 20px !important;
            list-style: none !important;
            margin: 0 !important;
            padding: 0 !important;
        }
        .nav-item {
            text-decoration: none !important;
            color: #374151 !important;
            display: flex !important;
            align-items: center !important;
            gap: 8px !important;
            font-size: 14px !important;
            padding: 8px 12px !important;
        }
        .nav-item.active {
            color: #dc2626 !important;
            font-weight: bold !important;
            border-bottom: 3px solid #dc2626 !important;
        }
        .nav-icon {
            font-size: 16px !important;
        }
        .info-derecha-widgets {
            display: flex !important;
            align-items: center !important;
            gap: 20px !important;
        }
        .user-tag {
            display: flex !important;
            align-items: center !important;
            gap: 8px !important;
            font-size: 14px !important;
            font-weight: bold !important;
        }
        .widget-ingresos {
            display: flex !important;
            align-items: center !important;
            gap: 6px !important;
            background-color: #e5e7eb !important;
            padding: 6px 12px !important;
            border-radius: 15px !important;
            font-size: 13px !important;
            font-weight: 500 !important;
        }
    </style>
</head>
<body>

    <header class="main-header">
        <div class="header-left">
            <a href="/ingreso-productos">
                <img src="favicons/android-chrome-192x192.png" alt="Logo" class="logo-img">
            </a>
        </div>
        <div class="centered-clock">
            <span id="reloj-fecha">Cargando fecha...</span>
            <span id="reloj-hora"></span>
        </div>
        <nav class="header-right">
            <a href="/logout" class="logout-btn" data-i18n="btn.cerrar_sesion">Cerrar Sesión</a>
        </nav>
    </header>

    <div class="user-info-bar">
        <nav class="header-nav">
            <ul class="nav-main-horizontal">
                <li>
                    <a href="/ingreso-productos" class="nav-item active">
                        <i class="fa-solid fa-arrow-down-left-from-square nav-icon"></i>
                        <span data-i18n="nav.ingreso">Ingreso</span>
                    </a>
                </li>
                <li>
                    <a href="/averias" class="nav-item">
                        <i class="fa-solid fa-triangle-exclamation nav-icon"></i>
                        <span data-i18n="nav.averias">Averías</span>
                    </a>
                </li>
                <li>
                    <a href="/registros" class="nav-item">
                        <i class="fa-solid fa-clipboard-list nav-icon"></i>
                        <span data-i18n="nav.registros">Registros</span>
                    </a>
                </li>
                <li>
                    <a href="/subir" class="nav-item">
                        <i class="fa-solid fa-file-import nav-icon"></i>
                        <span data-i18n="nav.importar">Importar</span>
                    </a>
                </li>
            </ul>
        </nav>

        <div class="info-derecha-widgets">
            <div class="widget-ingresos">
                <i class="fa-solid fa-boxes-stacked" style="color: #4b5563;"></i>
                <span data-i18n="label.ingresos_hoy">Ingresos hoy:</span>
                <span id="contador-ingresos" style="font-weight: bold; color: #dc2626;">0</span>
            </div>

            <div class="user-tag">
                <i class="fa-solid fa-circle-user" style="color: red;"></i>
                <span data-i18n="label.hola">Hola:</span> <span id="nombre-usuario-display">claudia</span>
            </div>
        </div>
    </div>

    <main class="container">
        <div class="form-section">
            <h2 data-i18n="formulario.titulo">Formulario de Ingreso</h2>
            
            <form id="form-ingreso">
                <div class="form-group">
                    <label for="codigo-barras" data-i18n="formulario.codigo">Código de Barras:</label>
                    <input type="text" id="codigo-barras" required placeholder="Escanee o escriba el código">
                </div>

                <div class="form-group">
                    <label for="nombre-producto" data-i18n="formulario.producto">Producto:</label>
                    <input type="text" id="nombre-producto" required>
                </div>

                <div class="form-group">
                    <label for="cantidad" data-i18n="formulario.cantidad">Cantidad:</label>
                    <input type="number" id="cantidad" required min="1">
                </div>

                <button type="submit" class="btn-submit" data-i18n="formulario.guardar">Guardar Ingreso</button>
            </form>
        </div>
    </main>

    <script>
        function actualizarReloj() {
            const ahora = new Date();
            const opcionesFecha = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            document.getElementById('reloj-fecha').textContent = ahora.toLocaleDateString('es-ES', opcionesFecha);
            document.getElementById('reloj-hora').textContent = ahora.toLocaleTimeString('es-ES');
        }
        setInterval(actualizarReloj, 1000);
        actualizarReloj();
    </script>

    <script src="js/i18n.js?v=1.1" type="module"></script>
    <script src="js/ingreso-productos.js?v=1.1" type="module"></script>
    <script src="js/common.js?v=1.1" type="module"></script>
</body>
</html>
