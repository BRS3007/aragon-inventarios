<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Importar - ARAGON</title>

    <link rel="icon" type="image/png" href="favicons/apple-touch-icon.png"> 
    <link rel="manifest" href="favicons/site.webmanifest"> 
    <link rel="mask-icon" href="favicons/safari-pinned-tab.svg" color="#5bbad5">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        body { font-family: 'Inter', sans-serif; }

        /* HEADER ESTILIZADO */
        .main-header {
            display: flex !important;
            justify-content: space-between !important;
            align-items: center !important;
            padding: 10px 20px !important;
            background-color: #ffffff !important;
            border-bottom: 1px solid #e5e7eb !important;
            height: 90px !important;
        }
        .logo-img { height: 75px !important; width: auto !important; }
        
        /* RELOJ BLINDADO */
        .centered-clock {
            display: flex !important;
            flex-direction: column !important;
            align-items: center !important;
            justify-content: center !important;
            background-color: #f9fafb !important;
            padding: 5px 15px !important;
            border-radius: 6px !important;
            border: 1px solid #e5e7eb !important;
            height: 65px !important; 
        }
        #reloj-fecha { font-size: 13px !important; color: #4b5563 !important; }
        #reloj-hora { font-size: 14px !important; font-weight: bold !important; color: #dc2626 !important; }

        /* BOTÓN SALIR */
        .logout-btn {
            display: inline-block !important;
            background-color: #dc2626 !important;
            color: #ffffff !important;
            padding: 10px 20px !important;
            border-radius: 6px !important;
            font-weight: bold !important;
            text-decoration: none !important;
        }

        /* WIDGETS DE NAVEGACIÓN PC */
        .nav-main-horizontal {
            display: flex; gap: 20px; list-style: none; padding: 10px 20px;
            border-bottom: 1px solid #e5e7eb; background-color: #ffffff;
        }
        .nav-item {
            text-decoration: none; color: #374151; display: flex;
            align-items: center; gap: 8px; font-size: 14px; padding: 8px 12px; border-radius: 6px;
        }
        .nav-item:hover { background-color: #f3f4f6; }
        .nav-item.active {
            color: #dc2626; font-weight: bold; border-bottom: 3px solid #dc2626; border-radius: 6px 6px 0 0;
        }

        /* DISEÑO MÓVIL */
        @media (max-width: 768px) {
            .main-header { flex-direction: column !important; height: auto !important; gap: 12px !important; padding: 15px !important; text-align: center !important; }
            .centered-clock { width: 90% !important; max-width: 250px !important; margin: 0 auto !important; }
            .nav-main-horizontal { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; padding: 10px; }
            .nav-item { justify-content: center; background-color: #f9fafb; border: 1px solid #e5e7eb; }
            .nav-item.active { border: 1px solid #dc2626; }
        }
    </style>
</head>
<body class="bg-gray-50">

    <header class="main-header">
        <div class="header-left">
            <a href="/ingreso-productos">
                <img src="favicons/android-chrome-192x192.png" alt="Logo" class="logo-img">
            </a>
        </div>
        <div class="centered-clock">
            <span id="reloj-fecha">Cargando fecha...</span>
            <span id="reloj-hora"></span>
        </div>
        <nav class="header-right">
            <a href="/logout" class="logout-btn">Cerrar Sesión</a>
        </nav>
    </header>

    <div class="user-info-bar">
        <nav class="header-nav">
            <ul class="nav-main-horizontal">
                <li><a href="/ingreso-productos" class="nav-item"><span>📥</span> Ingreso</a></li>
                <li><a href="/averias" class="nav-item"><span>⚠️</span> Averías</a></li>
                <li><a href="/registros" class="nav-item"><span>📋</span> Registros</a></li>
                <li><a href="/subir" class="nav-item active"><span>🚀</span> Importar</a></li>
            </ul>
        </nav>
        <div class="px-5 py-2 text-sm text-gray-600 flex items-center gap-2">
            <i class="fa-solid fa-circle-user text-red-600"></i>
            <span>Hola: <strong>claudia</strong></span>
        </div>
    </div>

    <main class="max-w-4xl mx-auto px-4 py-12 flex justify-center">
        <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-2xl border border-gray-100">
            <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Subir Productos</h1>
            <form id="upload-form" class="space-y-6">
                <div>
                    <label for="excel-file" class="block text-sm font-medium text-gray-700">Selecciona tu archivo Excel (.xlsx):</label>
                    <input type="file" id="excel-file" accept=".xlsx, .xls" required class="mt-2 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-red-50 file:text-red-700 hover:file:bg-red-100 cursor-pointer">
                </div>
                <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 font-bold">
                    Procesar y Subir
                </button>
            </form>
            <div class="mt-6 border-t pt-4">
                <h2 class="text-xl font-bold text-gray-800">Resultado:</h2>
                <div id="status-message" class="text-center font-bold mt-2 text-gray-600"></div>
            </div>
        </div>
    </main>

    <script>
        function actualizarReloj() {
            const ahora = new Date();
            const opcionesFecha = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            const fechaTexto = ahora.toLocaleDateString('es-ES', opcionesFecha).replace(',', '');
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const segundos = String(ahora.getSeconds()).padStart(2, '0');
            const horaTexto = `${horas}:${minutos}:${segundos}`;
            document.getElementById('reloj-fecha').textContent = fechaTexto;
            document.getElementById('reloj-hora').textContent = horaTexto;
        }
        actualizarReloj();
        setInterval(actualizarReloj, 1000);
    </script>
    <script src="js/i18n.js" type="module"></script>
    <script src="js/subir.js" type="module"></script>
    <script src="js/common.js" type="module"></script>
</body>
</html>
