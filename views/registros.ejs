<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registros</title>
   <!-- INICIO: Codigo de Favicons Corregido y Optimizado -->
     <link rel="icon" type="image/png" href="favicons/android-chrome-512x512.png"> 
    <!-- Asegurate que todos estos archivos esten en la carpeta 'public/favicons/' -->
    <link rel="apple-touch-icon" sizes="180x180" href="favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="favicons/favicon-16x16.png">
    <link rel="manifest" href="favicons/site.webmanifest"> <!-- Ruta corregida para el manifest -->
    <link rel="mask-icon" href="favicons/safari-pinned-tab.svg" color="#5bbad5">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">
    <link rel="icon" href="favicons/android-chrome-192x192.png" type="image/x-icon"> <!-- El favicon principal en formato .ico -->
    <!-- FIN: Codigo de Favicons Corregido y Optimizado -->
    
    <!--<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">-->
    
    <link rel="stylesheet" href="css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"crossorigin="anonymous">
</head>
<body class="background-login">
    
    <header class="main-header">
        <div class="header-left">
            <a href="/ingreso-productos">
                <img src="favicons/android-chrome-192x192.png" alt="Logo" class="logo-img">
            </a>
        </div>

        <div id="live-clock" class="centered-clock">
            <span id="reloj-fecha">Cargando fecha...</span>
            <span id="reloj-hora"></span>
        </div>

        <nav class="header-right">
            <ul class="nav-list">
                <li>
                    <a href="/logout" class="logout-btn">
                        <i class="fa-solid fa-arrow-right-from-bracket"></i> Cerrar Sesión
                    </a>
                </li>
            </ul>
        </nav>
    </header>

    <div class="user-info-bar">
        <nav class="header-nav">
            <ul class="nav-main-horizontal">
                <li>
                    <a href="/ingreso-productos" class="nav-item">
                        <span class="nav-icon"><i class="fa-solid fa-boxes-packing"></i></span>
                        <span class="nav-text" data-i18n="common:product_entry_link">Ingreso</span>
                    </a>
                </li>
                <li>
                    <a href="/averias" class="nav-item">
                        <span class="nav-icon"><i class="fa-solid fa-triangle-exclamation"></i></span>
                        <span class="nav-text" data-i18n="common:report_damage_link">Averías</span>
                    </a>
                </li>
                <li class="admin-only">
                    <a href="/registros" class="nav-item">
                        <span class="nav-icon"><i class="fa-solid fa-list-check"></i></span>
                        <span class="nav-text" data-i18n="common:recorded_entries_link">Registros</span>
                    </a>
                </li>
                <li class="admin-only">
                    <a href="/subir" class="nav-item">
                        <span class="nav-icon"><i class="fa-solid fa-file-arrow-up"></i></span>
                        <span class="nav-text" data-i18n="common:import_link">Importar</span>
                    </a>
                </li>
            </ul>
        </nav>

        <div class="sesion-contador">
            <i class="fa-solid fa-box"></i> Ingresos hoy: <span id="contador-ingresos">0</span>
        </div>
        
        <div class="user-tag">
            <i class="fa-solid fa-circle-user" style="color: red;"></i>
            <span id="nombre-usuario-display">Cargando...</span>
        </div>
    </div>

    <div class="notificacion-contenedor admin-only" onclick="abrirModalAprobaciones()">
        <span class="icono-usuarios"><i class="fa-solid fa-bell"></i></span>
        <span id="contador-badge" class="badge" style="display: none;">0</span>
    </div>
    
<main id="app-container">
    </main>
    <main class="container">
    <h1 class="page-title" data-i18n="registros:page_title">Ingresos de Productos Realizados</h1>

    <div class="toolbar-container">
        
        <div class="search-group">
            <div class="input-with-icon">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="search-input" placeholder="Buscar por código o descripción..." class="search-input">
            </div>
            <button id="clear-search-btn" class="common:btn-text">Limpiar</button>
        </div>

        <div class="filter-group">
            <div class="date-input">
    <label for="fecha-inicio" data-i18n="common:date_start_label">Inicio</label>
    <input type="date" id="fecha-inicio">
</div>
<div class="date-input">
    <label for="fecha-fin" data-i18n="common:date_end_label">Fin</label>
    <input type="date" id="fecha-fin">
</div>
            <div class="filter-actions">
<button id="filter-btn" class="btn-action" data-tooltip="Aplicar filtro de fecha" onclick="cargarProductosFiltrados()">
    <i class="fa-solid fa-filter"></i>
</button>

<button id="clear-filter-btn" class="btn-action btn-clear" title="Borrar filtros y ver todo">
    <i class="fa-solid fa-trash-can"></i>
</button>

<a id="export-excel-btn" class="btn-excel" href="#" title="Descargar reporte en Excel">
    <i class="fa-solid fa-file-excel"></i>
    <span>Exportar</span>
</a>
        </div>
    </div>

<div class="pagination-container" style="display: flex; justify-content: center; align-items: center; gap: 10px; margin: 10px 0;">
    <button onclick="paginaAnterior()" class="btn-paging"> <i class="fas fa-chevron-left"></i> Anterior</button>
    <span id="n-pagina" style="font-weight: bold; background: #eee; padding: 5px 12px; border-radius: 4px;">1</span>
    <button onclick="paginaSiguiente()" class="btn-paging">Siguiente <i class="fas fa-chevron-right"></i></button>
</div>

<div class="table-container">
    <table id="productos-table">
        <thead>
            <tr>
                <th>Código de Barras</th>
                <th>Código</th>
                <th>Descripción</th>
                <th>Cantidad</th>
                <th>Fecha</th>
                <th>Precio</th>
                <th>Pasillo</th>
                <th>Acciones</th> 
            </tr>
        </thead>
        <tbody id="cuerpo-tabla-principal">
            </tbody>
    </table>
    <p id="no-products-message" style="display:none; text-align: center; color: #888; margin-top: 20px;">No se encontraron productos.</p>
</div>
    </main>

    <div id="modal-historial" class="custom-modal" style="display: none;">
    <div class="modal-card">
        <div class="modal-header">
            <h3><i class="fa-solid fa-clock-rotate-left"></i> Historial de Registros</h3>
        </div>
        
        <div class="modal-content">
            <div class="table-container-modal">
                <table>
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Tipo</th>
                            <th>Cant.</th>
                            <th>Precio</th>
                            <th>Ubicación</th>
                            <th>Usuario</th>
                        </tr>
                    </thead>
                    <tbody id="cuerpo-historial">
                        </tbody>
                </table>
            </div>
        </div>
        <div class="modal-footer">
            <button onclick="cerrarModal()" class="btn-close">Cerrar</button>
            </div>

            <button onclick="descargarHistorialPDF()" class="btn-pdf-elegante shadow-sm">
    <i class="fas fa-file-pdf"></i> Descargar Reporte PDF
</button>
        </div>
    </div>
</div>
     <!-- El script para esta página -->
      
    <script type="importmap">
{
  "imports": {
    "i18next": "https://cdn.jsdelivr.net/npm/i18next@23.11.5/+esm",
    "i18next-http-backend": "https://cdn.jsdelivr.net/npm/i18next-http-backend@2.5.2/+esm",
    "i18next-browser-languagedetector": "https://cdn.jsdelivr.net/npm/i18next-browser-languagedetector@8.0.0/+esm",
    "sweetalert2": "https://cdn.jsdelivr.net/npm/sweetalert2@11.10.8/+esm"
  }
}
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

    <script src="js/i18n.js?v=1.2" type="module"></script>
    <script src="js/registros.js?v=1.2" type="module"></script>
    <script src="js/common.js?v=1.2" type="module"></script>
</body>
</html>