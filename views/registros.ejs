<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registros - ARAGON</title>
    
    <link rel="icon" type="image/png" href="favicons/android-chrome-512x512.png"> 
    <link rel="apple-touch-icon" sizes="180x180" href="favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="favicons/favicon-16x16.png">
    <link rel="manifest" href="favicons/site.webmanifest"> 
    <link rel="mask-icon" href="favicons/safari-pinned-tab.svg" color="#5bbad5">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">
    <link rel="icon" href="favicons/android-chrome-192x192.png" type="image/x-icon"> 
    <link rel="stylesheet" href="css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous">

    <style>
        /* ==========================================
           1. ESTILOS BASE Y PARA PC (Header y Widgets)
           ========================================== */
        
        /* Header Horizontal Indestructible */
        .main-header {
            display: flex !important;
            justify-content: space-between !important;
            align-items: center !important;
            padding: 10px 20px !important;
            background-color: #ffffff !important;
            border-bottom: 1px solid #e5e7eb !important;
            height: 90px !important;
        }

        .logo-img {
            height: 75px !important;
            width: auto !important;
        }

        /* Reloj Pequeño que NO estira la barra */
        .centered-clock {
            display: flex !important;
            flex-direction: column !important;
            align-items: center !important;
            justify-content: center !important;
            background-color: #f9fafb !important;
            padding: 5px 15px !important;
            border-radius: 6px !important;
            border: 1px solid #e5e7eb !important;
            height: 65px !important; 
        }
        #reloj-fecha { 
            font-size: 13px !important; 
            color: #4b5563 !important; 
        }
        #reloj-hora { 
            font-size: 14px !important; 
            font-weight: bold !important; 
            color: #dc2626 !important; 
        }

        /* Botón Cerrar Sesión Rojo */
        .logout-btn {
            display: inline-block !important;
            background-color: #dc2626 !important;
            color: #ffffff !important;
            padding: 10px 20px !important;
            border-radius: 6px !important;
            font-weight: bold !important;
            text-decoration: none !important;
            transition: background-color 0.2s;
        }
        .logout-btn:hover {
            background-color: #b91c1c !important;
        }

        /* Barra de navegación (Widgets) simulación PC */
        .nav-main-horizontal {
            display: flex;
            gap: 20px;
            list-style: none;
            padding: 10px 20px;
            border-bottom: 1px solid #e5e7eb;
            background-color: #ffffff;
        }
        .nav-item {
            text-decoration: none;
            color: #374151;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            padding: 8px 12px;
            border-radius: 6px;
        }
        .nav-item:hover {
            background-color: #f3f4f6;
        }
        .nav-item.active {
            color: #dc2626;
            font-weight: bold;
            border-bottom: 3px solid #dc2626;
            border-radius: 6px 6px 0 0;
        }

        /* ==================================================
           TABLAS INDESTRUCTIBLES CON SCROLL EN CELULAR
           ================================================== */
        
        /* Scroll para la tabla principal */
        .table-container {
            width: 100% !important;
            overflow-x: auto !important;
            -webkit-overflow-scrolling: touch;
            margin-top: 15px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
        }
        #productos-table {
            min-width: 900px !important; /* Mantiene el tamaño para que no se apriete */
        }

        /* Scroll para la tabla del modal (Historial) */
        .table-container-modal {
            width: 100% !important;
            overflow-x: auto !important;
            -webkit-overflow-scrolling: touch;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
        }
        .table-container-modal table {
            min-width: 650px !important; /* Asegura que la tabla modal no se apachurre */
        }

        /* ==========================================
           2. ESTILOS PARA CELULAR (MENOS DE 768px)
           ========================================== */
        @media (max-width: 768px) {
            .main-header {
                flex-direction: column !important;
                height: auto !important;
                gap: 12px !important;
                padding: 15px !important;
                text-align: center !important;
            }

            .centered-clock {
                width: 90% !important;
                max-width: 250px !important;
                margin: 0 auto !important;
            }

            /* Los Widgets se vuelven una cuadrícula de 2x2 en celular */
            .nav-main-horizontal {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 10px;
                padding: 10px;
            }
            .nav-item {
                justify-content: center;
                background-color: #f9fafb;
                border: 1px solid #e5e7eb;
            }
            .nav-item.active {
                border: 1px solid #dc2626;
            }

            /* Los filtros se amontonaban, esto los ordena en columna */
            .toolbar-container {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }
            .filter-group {
                flex-direction: column;
                align-items: stretch;
            }
        }
    </style>
</head>
<body class="background-login">

    <header class="main-header">
        <div class="header-left">
            <a href="/ingreso-productos">
                <img src="favicons/android-chrome-192x192.png" alt="Logo" class="logo-img">
            </a>
        </div>

        <div class="centered-clock">
            <span id="reloj-fecha">Cargando fecha...</span>
            <span id="reloj-hora"></span>
        </div>

        <nav class="header-right">
            <a href="/logout" class="logout-btn" data-i18n="common.logout_button">Cerrar Sesión</a>
        </nav>
    </header>

    <div class="user-info-bar">
        <nav class="header-nav">
            <ul class="nav-main-horizontal">
                <li>
                    <a href="/ingreso-productos" class="nav-item">
                        <span>📥</span> Ingreso
                    </a>
                </li>
                <li>
                    <a href="/averias" class="nav-item">
                        <span>⚠️</span> Averías
                    </a>
                </li>
                <li>
                    <a href="/registros" class="nav-item active">
                        <span>📋</span> Registros
                    </a>
                </li>
                <li>
                    <a href="/subir" class="nav-item">
                        <span>🚀</span> Importar
                    </a>
                </li>
            </ul>
        </nav>
        
        <div class="px-5 py-2 text-sm text-gray-600 flex items-center gap-2">
            <i class="fa-solid fa-circle-user" style="color: red;"></i>
            <span id="nombre-usuario-display">Cargando...</span>
        </div>
    </div>

    <main class="container">
        <h1 class="page-title" data-i18n="registros:page_title">Ingresos de Productos Realizados</h1>

        <div class="toolbar-container">
            <div class="search-group">
                <div class="input-with-icon">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" id="search-input" placeholder="Buscar por código o descripción..." class="search-input">
                </div>
                <button id="clear-search-btn" class="common:btn-text">Limpiar</button>
            </div>

            <div class="filter-group">
                <div class="date-input">
                    <label for="fecha-inicio" data-i18n="common:date_start_label">Inicio</label>
                    <input type="date" id="fecha-inicio">
                </div>
                <div class="date-input">
                    <label for="fecha-fin" data-i18n="common:date_end_label">Fin</label>
                    <input type="date" id="fecha-fin">
                </div>
                <div class="filter-actions">
                    <button id="filter-btn" class="btn-action" data-tooltip="Aplicar filtro de fecha" onclick="cargarProductosFiltrados()">
                        <i class="fa-solid fa-filter"></i>
                    </button>

                    <button id="clear-filter-btn" class="btn-action btn-clear" title="Borrar filtros y ver todo">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>

                    <a id="export-excel-btn" class="btn-excel" href="#" title="Descargar reporte en Excel">
                        <i class="fa-solid fa-file-excel"></i>
                        <span>Exportar</span>
                    </a>
                </div>
            </div>

            <div class="pagination-container" style="display: flex; justify-content: center; align-items: center; gap: 10px; margin: 10px 0;">
                <button onclick="paginaAnterior()" class="btn-paging"> <i class="fas fa-chevron-left"></i> Anterior</button>
                <span id="n-pagina" style="font-weight: bold; background: #eee; padding: 5px 12px; border-radius: 4px;">1</span>
                <button onclick="paginaSiguiente()" class="btn-paging">Siguiente <i class="fas fa-chevron-right"></i></button>
            </div>

            <div class="table-container">
                <table id="productos-table">
                    <thead>
                        <tr>
                            <th>Código de Barras</th>
                            <th>Código</th>
                            <th>Descripción</th>
                            <th>Cantidad</th>
                            <th>Fecha</th>
                            <th>Precio</th>
                            <th>Pasillo</th>
                            <th>Acciones</th> 
                        </tr>
                    </thead>
                    <tbody id="cuerpo-tabla-principal">
                    </tbody>
                </table>
                <p id="no-products-message" style="display:none; text-align: center; color: #888; margin-top: 20px;">No se encontraron productos.</p>
            </div>
    </main>

    <div id="modal-historial" class="custom-modal" style="display: none;">
        <div class="modal-card">
            <div class="modal-header">
                <h3><i class="fa-solid fa-clock-rotate-left"></i> Historial de Registros</h3>
            </div>
            
            <div class="modal-content">
                <div class="table-container-modal">
                    <table>
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th>Cant.</th>
                                <th>Precio</th>
                                <th>Ubicación</th>
                                <th>Usuario</th>
                            </tr>
                        </thead>
                        <tbody id="cuerpo-historial">
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button onclick="cerrarModal()" class="btn-close">Cerrar</button>
                <button onclick="descargarHistorialPDF()" class="btn-pdf-elegante shadow-sm">
                    <i class="fas fa-file-pdf"></i> Descargar Reporte PDF
                </button>
            </div>
        </div>
    </div>

    <script>
        function actualizarReloj() {
            const ahora = new Date();
            const opcionesFecha = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            const fechaTexto = ahora.toLocaleDateString('es-ES', opcionesFecha).replace(',', '');
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const segundos = String(ahora.getSeconds()).padStart(2, '0');
            const horaTexto = `${horas}:${minutos}:${segundos}`;
            
            document.getElementById('reloj-fecha').textContent = fechaTexto;
            document.getElementById('reloj-hora').textContent = horaTexto;
        }
        actualizarReloj();
        setInterval(actualizarReloj, 1000);
    </script>

    <script type="importmap">
    {
      "imports": {
        "i18next": "https://cdn.jsdelivr.net/npm/i18next@23.11.5/+esm",
        "i18next-http-backend": "https://cdn.jsdelivr.net/npm/i18next-http-backend@2.5.2/+esm",
        "i18next-browser-languagedetector": "https://cdn.jsdelivr.net/npm/i18next-browser-languagedetector@8.0.0/+esm",
        "sweetalert2": "https://cdn.jsdelivr.net/npm/sweetalert2@11.10.8/+esm"
      }
    }
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="js/i18n.js" type="module"></script>
    <script src="js/registros.js" type="module"></script>
    <script src="js/common.js" type="module"></script>
</body>
</html>
