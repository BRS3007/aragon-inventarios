<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reportar Avería</title>
    <!-- Favicons (asegurate de que las rutas sean correctas, ej. favicons/favicon-32x32.png) -->
    <link rel="apple-touch-icon" sizes="180x180" href="favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="favicons/favicon-16x16.png">
    <link rel="manifest" href="favicons/site.webmanifest">
    <link rel="mask-icon" href="favicons/safari-pinned-tab.svg" color="#5bbad5">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">
    <link rel="icon" href="favicons/android-chrome-192x192.png" type="image/x-icon">

    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="css/styles.css?v=13.0">
    <link href="/dist/output.css" rel="stylesheet">
</head>
<body class="background-login">
    <header class="main-header">
        <div class="header-left">
            <a href="/ingreso-productos">
                <img src="favicons/android-chrome-192x192.png" alt="Logo" class="logo-img">
            </a>
        </div>

        <div id="live-clock" class="centered-clock">
            <span id="reloj-fecha">Cargando fecha...</span>
            <span id="reloj-hora"></span>
        </div>

        <nav class="header-right">
            <ul class="nav-list">
                <li>
                    <a href="/logout" class="logout-btn">
                        <i class="fa-solid fa-arrow-right-from-bracket"></i> Cerrar Sesión
                    </a>
                </li>
            </ul>
        </nav>
    </header>

    <div class="user-info-bar">
        <nav class="header-nav">
            <ul class="nav-main-horizontal">
                <li>
                    <a href="/ingreso-productos" class="nav-item">
                        <span class="nav-icon"><i class="fa-solid fa-boxes-packing"></i></span>
                        <span class="nav-text" data-i18n="common:product_entry_link">Ingreso</span>
                    </a>
                </li>
                <li>
                    <a href="/averias" class="nav-item">
                        <span class="nav-icon"><i class="fa-solid fa-triangle-exclamation"></i></span>
                        <span class="nav-text" data-i18n="common:report_damage_link">Averías</span>
                    </a>
                </li>
                <li class="admin-only">
                    <a href="/registros" class="nav-item">
                        <span class="nav-icon"><i class="fa-solid fa-list-check"></i></span>
                        <span class="nav-text" data-i18n="common:recorded_entries_link">Registros</span>
                    </a>
                </li>
                <li class="admin-only">
                    <a href="/subir" class="nav-item">
                        <span class="nav-icon"><i class="fa-solid fa-file-arrow-up"></i></span>
                        <span class="nav-text" data-i18n="common:import_link">Importar</span>
                    </a>
                </li>
            </ul>
        </nav>

        <div class="sesion-contador">
            <i class="fa-solid fa-box"></i> Ingresos hoy: <span id="contador-ingresos">0</span>
        </div>
        
        <div class="user-tag">
            <i class="fa-solid fa-circle-user" style="color: red;"></i>
            <span id="nombre-usuario-display">Cargando...</span>
        </div>
    </div>
    
<main id="app-container">
    </main>
    <main class="container">
    <div class="header-with-langs">
        <h1 class="page-title" data-i18n="averias:page_title">Reportar Avería de Producto</h1>
        </div>

    <form id="form-reportar-averia" class="form-grid">
        <div class="form-row">
            <div class="form-group">
                <label for="codigo_de_barras_averia" data-i18n="averias:barcode_label">Código de Barras:</label>
                <input type="text" id="codigo_de_barras_averia" name="codigo_de_barras" required>
                <small class="help-text">Introduce el código de barras del producto.</small>
            </div>

            <div class="form-group">
                <label for="cantidad_averia" data-i18n="averias:quantity_label">Cantidad:</label>
                <input type="number" id="cantidad_averia" name="cantidad" min="1" value="1" required>
                <small class="help-text">Indica la cantidad que se descontará del stock.</small>
            </div>

            <div class="form-group">
                <label for="descripcion_producto_averia" data-i18n="averias:product_description_label">Descripción:</label>
                <input type="text" id="descripcion_producto_averia" name="descripcion_producto" readonly>
                <small class="help-text">Se autocompletará automáticamente.</small>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="descripcion_averia" data-i18n="averias:damage_description_label">Motivo de Avería:</label>
                <input type="text" id="descripcion_averia" name="descripcion_averia" required>
                <small class="help-text">Detalla el daño (ej: empaque roto).</small>
            </div>

            <div class="form-group">
                <label for="fecha_averia" data-i18n="averias:damage_date_label">Fecha:</label>
                <input type="date" id="fecha_averia" name="fecha_averia" required>
                <small class="help-text">Selecciona la fecha del reporte.</small>
            </div>

            <div class="form-group">
                <label for="estado_averia" data-i18n="averias:status_label">Estado:</label>
                <select id="estado_averia" name="estado" required>
                    <option value="Pendiente" data-i18n="averias:status_pending">Pendiente</option>
                    <option value="En Revisión" data-i18n="averias:status_in_review">En Revisión</option>
                    <option value="Descartado" data-i18n="averias:status_discarded">Descartado</option>
                </select>
                <small class="help-text">Estado actual del proceso.</small>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary-red">Reportar Avería</button>
            <button type="button" class="btn-secondary-red" id="btn-limpiar-averia">
                <i class="fas fa-trash"></i> Limpiar Formulario
            </button>
        </div>
    </form>
</main>
    
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const rol = localStorage.getItem('userRole');
        // Si el usuario no es admin, borramos los elementos prohibidos
        if (rol !== 'admin') {
            document.querySelectorAll('.admin-only').forEach(el => el.remove());
        }
    });
</script>

<script type="importmap">
{
  "imports": {
    "i18next": "https://cdn.jsdelivr.net/npm/i18next@23.11.5/+esm",
    "i18next-http-backend": "https://cdn.jsdelivr.net/npm/i18next-http-backend@2.5.2/+esm",
    "i18next-browser-languagedetector": "https://cdn.jsdelivr.net/npm/i18next-browser-languagedetector@8.0.0/+esm",
    "sweetalert2": "https://cdn.jsdelivr.net/npm/sweetalert2@11.10.8/+esm"
  }
}
</script>
    <script src="js/i18n.js?v=1.2" type="module"></script>
    <script src="js/averias.js?v=1.2" type="module"></script> <!-- Script para la lógica de averías -->
    <script src="js/common.js?v=1.2" type="module"></script>  
</body>
</html>