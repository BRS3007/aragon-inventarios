<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reportar Avería - ARAGON</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        /* ==========================================
           1. ESTILOS PARA PC (POR DEFECTO)
           ========================================== */
        
        /* Estilos del Header para que se vea horizontal en PC */
        .main-header {
            display: flex !important;
            justify-content: space-between !important;
            align-items: center !important;
            padding: 10px 20px !important;
            background-color: #ffffff !important;
            border-bottom: 1px solid #e5e7eb !important;
            height: 90px !important;
        }

        .logo-img {
            height: 75px !important;
            width: auto !important;
        }

        .centered-clock {
            display: flex !important;
            flex-direction: column !important;
            align-items: center !important;
            justify-content: center !important;
            background-color: #f9fafb !important;
            padding: 10px 20px !important;
            border-radius: 8px !important;
            border: 1px solid #e5e7eb !important;
        }

        .logout-btn {
            display: inline-block !important;
            background-color: #dc2626 !important;
            color: #ffffff !important;
            padding: 10px 20px !important;
            border-radius: 6px !important;
            font-weight: bold !important;
            text-decoration: none !important;
        }

        /* Tus estilos originales del formulario en PC */
        .form-row {
            display: flex;
            flex-direction: row;
            gap: 20px;
            margin-bottom: 20px;
        }
        .form-group {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        .form-group label {
            font-size: 0.875rem;
            font-weight: 500;
            color: #374151;
            margin-bottom: 4px;
        }
        .form-group input, .form-group select {
            padding: 12px;
            border: 1px solid #D1D5DB;
            border-radius: 8px;
        }
        .help-text {
            font-size: 0.75rem;
            color: #6B7280;
            margin-top: 4px;
        }
        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-top: 20px;
        }

        /* ==========================================
           2. ESTILOS PARA CELULAR (MENOS DE 768px)
           ========================================== */
        @media (max-width: 768px) {
            /* El Header se apila en vertical y se centra */
            .main-header {
                flex-direction: column !important;
                height: auto !important;
                gap: 15px !important;
                padding: 15px !important;
                text-align: center !important;
            }

            .logo-img {
                height: 60px !important;
                margin: 0 auto !important;
            }

            .centered-clock {
                width: 90% !important;
                max-width: 280px !important;
                margin: 0 auto !important;
            }

            /* Tus estilos originales del formulario en Celular */
            .form-row {
                flex-direction: column;
                gap: 15px;
            }
            .form-actions {
                flex-direction: column;
            }
            .form-actions button {
                width: 100%;
            }
        }
    </style>
</head>
<header class="main-header">
        
        <div class="header-left">
            <a href="/ingreso-productos">
                <img src="favicons/android-chrome-192x192.png" alt="Logo" class="h-24 mb-1">
            </a>
        </div>

        <div id="live-clock" class="centered-clock">
            <span id="reloj-fecha">Cargando fecha...</span>
            <span id="reloj-hora"></span>
        </div>

        <nav class="header-right">
            <ul class="nav-list">
                <li>
                    <a href="/logout" class="logout-btn">Cerrar Sesión</a>
                </li>
            </ul>
        </nav>
    </header>

    <div class="user-info-bar" style="margin-top: 20px;">
    <nav class="header-nav">
        <ul class="nav-main-horizontal">
            <li>
                <a href="/ingreso-productos" class="nav-item">
                    <span class="nav-icon">📥</span>
                    <span class="nav-text">Ingreso de Productos</span>
                </a>
            </li>
            <li>
                <a href="/averias" class="nav-item active" style="border-bottom: 3px solid #dc2626; font-weight: bold; color: #dc2626;">
                    <span class="nav-icon">⚠️</span>
                    <span class="nav-text">Reportar Avería</span>
                </a>
            </li>
            <li>
                <a href="/registros" class="nav-item">
                    <span class="nav-icon">📋</span>
                    <span class="nav-text">Ingresos Realizados</span>
                </a>
            </li>
            <li>
                <a href="/subir" class="nav-item">
                    <span class="nav-icon">🚀</span>
                    <span class="nav-text">Importar</span>
                </a>
            </li>
        </ul>
    </nav>

    <div class="user-tag">
            <i class="fa-solid fa-circle-user" style="color: red;"></i>
            <span id="nombre-usuario-display">Cargando...</span>
        </div>

    <main class="max-w-6xl mx-auto px-4 py-8">
        <div class="bg-white p-6 md:p-8 rounded-xl shadow-sm border border-gray-200">
            
            <div class="text-center md:text-left mb-6">
                <h2 class="text-3xl font-bold text-gray-900">Reportar Avería de Producto</h2>
            </div>

            <form id="form-reportar-averia" class="form-grid">
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="codigo_de_barras_averia" data-i18n="averias:barcode_label">Código de Barras:</label>
                        <input type="text" id="codigo_de_barras_averia" name="codigo_de_barras" required>
                        <small class="help-text">Introduce el código de barras del producto.</small>
                    </div>

                    <div class="form-group">
                        <label for="cantidad_averia" data-i18n="averias:quantity_label">Cantidad:</label>
                        <input type="number" id="cantidad_averia" name="cantidad" min="1" value="1" required>
                        <small class="help-text">Indica la cantidad que se descontará del stock.</small>
                    </div>

                    <div class="form-group">
                        <label for="descripcion_producto_averia" data-i18n="averias:product_description_label">Descripción:</label>
                        <input type="text" id="descripcion_producto_averia" name="descripcion_producto" class="bg-gray-100" readonly>
                        <small class="help-text">Se autocompletará automáticamente.</small>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="descripcion_averia" data-i18n="averias:damage_description_label">Motivo de Avería:</label>
                        <input type="text" id="descripcion_averia" name="descripcion_averia" required>
                        <small class="help-text">Detalla el daño (ej: empaque roto).</small>
                    </div>

                    <div class="form-group">
                        <label for="fecha_averia" data-i18n="averias:damage_date_label">Fecha:</label>
                        <input type="date" id="fecha_averia" name="fecha_averia" required>
                        <small class="help-text">Selecciona la fecha del reporte.</small>
                    </div>

                    <div class="form-group">
                        <label for="estado_averia" data-i18n="averias:status_label">Estado:</label>
                        <select id="estado_averia" name="estado" required>
                            <option value="Pendiente" data-i18n="averias:status_pending">Pendiente</option>
                            <option value="En Revisión" data-i18n="averias:status_in_review">En Revisión</option>
                            <option value="Descartado" data-i18n="averias:status_discarded">Descartado</option>
                        </select>
                        <small class="help-text">Estado actual del proceso.</small>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="bg-gray-500 hover:bg-gray-600 text-white font-bold py-3 px-6 rounded-lg transition" id="btn-limpiar-averia">
                        <i class="fas fa-trash mr-2"></i> Limpiar Formulario
                    </button>
                    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-8 rounded-lg transition">
                        Reportar Avería
                    </button>
                </div>
            </form>
        </div>
    </main>

    <script>
        function actualizarReloj() {
            const ahora = new Date();
            const opciones = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false };
            const textoFinal = ahora.toLocaleDateString('es-ES', opciones).replace(',', '');
            document.getElementById('reloj-vivo').innerText = textoFinal;
        }
        actualizarReloj();
        setInterval(actualizarReloj, 1000);
    </script>

</body>
</html>