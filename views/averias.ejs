<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reportar Avería - ARAGON</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        /* ==========================================
           1. ESTILOS BASE Y PARA PC
           ========================================== */
        
        /* Header Horizontal */
        .main-header {
            display: flex !important;
            justify-content: space-between !important;
            align-items: center !important;
            padding: 10px 20px !important;
            background-color: #ffffff !important;
            border-bottom: 1px solid #e5e7eb !important;
            height: 90px !important;
        }

        .logo-img {
            height: 75px !important;
            width: auto !important;
        }

        /* Reloj Pequeño que NO estira la barra */
        .centered-clock {
            display: flex !important;
            flex-direction: column !important;
            align-items: center !important;
            justify-content: center !important;
            background-color: #f9fafb !important;
            padding: 5px 15px !important;
            border-radius: 6px !important;
            border: 1px solid #e5e7eb !important;
            height: 65px !important; /* Altura fija */
        }
        #reloj-fecha { 
            font-size: 13px !important; 
            color: #4b5563 !important; 
        }
        #reloj-hora { 
            font-size: 14px !important; 
            font-weight: bold !important; 
            color: #dc2626 !important; 
        }

        /* Botón Cerrar Sesión Rojo */
        .logout-btn {
            display: inline-block !important;
            background-color: #dc2626 !important;
            color: #ffffff !important;
            padding: 10px 20px !important;
            border-radius: 6px !important;
            font-weight: bold !important;
            text-decoration: none !important;
            transition: background-color 0.2s;
        }
        .logout-btn:hover {
            background-color: #b91c1c !important;
        }

        /* Barra de navegación (Widgets) simulación PC */
        .nav-main-horizontal {
            display: flex;
            gap: 20px;
            list-style: none;
            padding: 10px 20px;
            border-bottom: 1px solid #e5e7eb;
            background-color: #ffffff;
        }
        .nav-item {
            text-decoration: none;
            color: #374151;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            padding: 8px 12px;
            border-radius: 6px;
        }
        .nav-item:hover {
            background-color: #f3f4f6;
        }
        .nav-item.active {
            color: #dc2626;
            font-weight: bold;
            border-bottom: 3px solid #dc2626;
            border-radius: 6px 6px 0 0;
        }

        /* Tus estilos originales del formulario */
        .form-row {
            display: flex;
            flex-direction: row;
            gap: 20px;
            margin-bottom: 20px;
        }
        .form-group {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        .form-group label {
            font-size: 0.875rem;
            font-weight: 500;
            color: #374151;
            margin-bottom: 4px;
        }
        .form-group input, .form-group select {
            padding: 12px;
            border: 1px solid #D1D5DB;
            border-radius: 8px;
        }
        .help-text {
            font-size: 0.75rem;
            color: #6B7280;
            margin-top: 4px;
        }
        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-top: 20px;
        }

        /* ==========================================
           2. ESTILOS PARA CELULAR (MENOS DE 768px)
           ========================================== */
        @media (max-width: 768px) {
            /* El Header se apila en vertical */
            .main-header {
                flex-direction: column !important;
                height: auto !important;
                gap: 12px !important;
                padding: 15px !important;
                text-align: center !important;
            }

            .centered-clock {
                width: 90% !important;
                max-width: 250px !important;
                margin: 0 auto !important;
            }

            /* Los Widgets se vuelven una cuadrícula de 2x2 en celular */
            .nav-main-horizontal {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 10px;
                padding: 10px;
            }
            .nav-item {
                justify-content: center;
                background-color: #f9fafb;
                border: 1px solid #e5e7eb;
            }
            .nav-item.active {
                border: 1px solid #dc2626;
            }

            /* El formulario se pone en vertical */
            .form-row {
                flex-direction: column;
                gap: 15px;
            }
            .form-actions {
                flex-direction: column;
            }
            .form-actions button {
                width: 100%;
            }
        }
    </style>
</head>
<body class="bg-gray-50">

    <header class="main-header">
        <div class="header-left">
            <a href="/ingreso-productos">
                <img src="favicons/android-chrome-192x192.png" alt="Logo" class="logo-img">
            </a>
        </div>

        <div class="centered-clock">
            <span id="reloj-fecha">Cargando fecha...</span>
            <span id="reloj-hora"></span>
        </div>

        <nav class="header-right">
            <a href="/logout" class="logout-btn">Cerrar Sesión</a>
        </nav>
    </header>

    <div class="user-info-bar">
        <nav class="header-nav">
            <ul class="nav-main-horizontal">
                <li>
                    <a href="/ingreso-productos" class="nav-item">
                        <span>📥</span> Ingreso
                    </a>
                </li>
                <li>
                    <a href="/averias" class="nav-item active">
                        <span>⚠️</span> Averías
                    </a>
                </li>
                <li>
                    <a href="/registros" class="nav-item">
                        <span>📋</span> Registros
                    </a>
                </li>
                <li>
                    <a href="/subir" class="nav-item">
                        <span>🚀</span> Importar
                    </a>
                </li>
            </ul>
        </nav>

        <div class="px-5 py-2 text-sm text-gray-600 flex items-center gap-2">
            <i class="fa-solid fa-circle-user text-red-600"></i>
            <span>Hola: <strong>claudia</strong></span>
        </div>
    </div>

    <main class="max-w-6xl mx-auto px-4 py-8">
        <div class="bg-white p-6 md:p-8 rounded-xl shadow-sm border border-gray-200">
            
            <div class="text-center md:text-left mb-6">
                <h2 class="text-3xl font-bold text-gray-900">Reportar Avería de Producto</h2>
            </div>

            <form id="form-reportar-averia">
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="codigo_de_barras_averia">Código de Barras:</label>
                        <input type="text" id="codigo_de_barras_averia" name="codigo_de_barras" required>
                        <small class="help-text">Introduce el código de barras del producto.</small>
                    </div>

                    <div class="form-group">
                        <label for="cantidad_averia">Cantidad:</label>
                        <input type="number" id="cantidad_averia" name="cantidad" min="1" value="1" required>
                        <small class="help-text">Indica la cantidad que se descontará del stock.</small>
                    </div>

                    <div class="form-group">
                        <label for="descripcion_producto_averia">Descripción:</label>
                        <input type="text" id="descripcion_producto_averia" name="descripcion_producto" class="bg-gray-100" readonly>
                        <small class="help-text">Se autocompletará automáticamente.</small>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="descripcion_averia">Motivo de Avería:</label>
                        <input type="text" id="descripcion_averia" name="descripcion_averia" required>
                        <small class="help-text">Detalla el daño (ej: empaque roto).</small>
                    </div>

                    <div class="form-group">
                        <label for="fecha_averia">Fecha:</label>
                        <input type="date" id="fecha_averia" name="fecha_averia" required>
                        <small class="help-text">Selecciona la fecha del reporte.</small>
                    </div>

                    <div class="form-group">
                        <label for="estado_averia">Estado:</label>
                        <select id="estado_averia" name="estado" required>
                            <option value="Pendiente">Pendiente</option>
                            <option value="En Revisión">En Revisión</option>
                            <option value="Descartado">Descartado</option>
                        </select>
                        <small class="help-text">Estado actual del proceso.</small>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="bg-gray-500 hover:bg-gray-600 text-white font-bold py-3 px-6 rounded-lg transition" id="btn-limpiar-averia">
                        <i class="fas fa-trash mr-2"></i> Limpiar Formulario
                    </button>
                    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-8 rounded-lg transition">
                        Reportar Avería
                    </button>
                </div>
            </form>
        </div>
    </main>

    <script>
        function actualizarReloj() {
            const ahora = new Date();
            
            // Opciones para la fecha
            const opcionesFecha = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            const fechaTexto = ahora.toLocaleDateString('es-ES', opcionesFecha).replace(',', '');
            
            // Opciones para la hora
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const segundos = String(ahora.getSeconds()).padStart(2, '0');
            const horaTexto = `${horas}:${minutos}:${segundos}`;
            
            // Inyectamos el texto en las etiquetas correspondientes
            document.getElementById('reloj-fecha').textContent = fechaTexto;
            document.getElementById('reloj-hora').textContent = horaTexto;
        }
        actualizarReloj();
        setInterval(actualizarReloj, 1000);
    </script>

</body>
</html>
