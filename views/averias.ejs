<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reportar Avería - ARAGON</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        .form-row {
            display: flex;
            flex-direction: row;
            gap: 20px;
            margin-bottom: 20px;
        }
        .form-group {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        .form-group label {
            font-size: 0.875rem;
            font-weight: 500;
            color: #374151;
            margin-bottom: 4px;
        }
        .form-group input, .form-group select {
            padding: 12px;
            border: 1px solid #D1D5DB;
            border-radius: 8px;
        }
        .help-text {
            font-size: 0.75rem;
            color: #6B7280;
            margin-top: 4px;
        }
        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-top: 20px;
        }

        /* 📱 Cuando se abra en un Celular se ponen en vertical */
        @media (max-width: 768px) {
            .form-row {
                flex-direction: column;
                gap: 15px;
            }
            .form-actions {
                flex-direction: column;
            }
            .form-actions button {
                width: 100%;
            }
        }
    </style>
</head>
<body class="bg-gray-50 font-sans">

    <header class="bg-white p-4 border-b border-gray-200">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row md:justify-between md:items-center space-y-4 md:space-y-0">
            
            <div class="flex flex-col items-center md:items-start">
                <img src="favicons/android-chrome-192x192.png" alt="Logo" class="h-24 mb-1">
            </div>

            <div class="flex flex-col items-center space-y-2">
                <div id="reloj-vivo" class="text-gray-600 text-sm text-center font-medium">
                    Cargando hora...
                </div>
                <a href="/logout" class="bg-red-600 text-white px-5 py-1.5 rounded-lg font-bold hover:bg-red-700 transition text-sm">
                    Cerrar Sesión
                </a>
            </div>

            <div class="flex flex-col items-center md:items-end space-y-3">
                <nav class="w-full">
                    <ul class="flex flex-col md:flex-row items-center space-y-2 md:space-y-0 md:space-x-4 text-sm font-medium text-gray-700">
                        <li><a href="/ingreso" class="flex items-center hover:text-red-600"><span class="mr-1">📥</span> Ingreso</a></li>
                        <li><a href="/averias" class="flex items-center text-red-600 font-bold border-b-2 border-red-600 pb-1"><span class="mr-1">⚠️</span> Averías</a></li>
                        <li><a href="/registros" class="flex items-center hover:text-red-600"><span class="mr-1">📋</span> Registros</a></li>
                        <li><a href="/importar" class="flex items-center hover:text-red-600"><span class="mr-1">🚀</span> Importar</a></li>
                    </ul>
                </nav>
                <div class="bg-gray-100 px-3 py-1 rounded-full text-xs font-semibold text-gray-600 flex items-center">
                    <span class="w-2 h-2 bg-red-500 rounded-full mr-1.5"></span> Hola: claudia
                </div>
            </div>

        </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-8">
        <div class="bg-white p-6 md:p-8 rounded-xl shadow-sm border border-gray-200">
            
            <div class="text-center md:text-left mb-6">
                <h2 class="text-3xl font-bold text-gray-900">Reportar Avería de Producto</h2>
            </div>

            <form id="form-reportar-averia" class="form-grid">
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="codigo_de_barras_averia" data-i18n="averias:barcode_label">Código de Barras:</label>
                        <input type="text" id="codigo_de_barras_averia" name="codigo_de_barras" required>
                        <small class="help-text">Introduce el código de barras del producto.</small>
                    </div>

                    <div class="form-group">
                        <label for="cantidad_averia" data-i18n="averias:quantity_label">Cantidad:</label>
                        <input type="number" id="cantidad_averia" name="cantidad" min="1" value="1" required>
                        <small class="help-text">Indica la cantidad que se descontará del stock.</small>
                    </div>

                    <div class="form-group">
                        <label for="descripcion_producto_averia" data-i18n="averias:product_description_label">Descripción:</label>
                        <input type="text" id="descripcion_producto_averia" name="descripcion_producto" class="bg-gray-100" readonly>
                        <small class="help-text">Se autocompletará automáticamente.</small>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="descripcion_averia" data-i18n="averias:damage_description_label">Motivo de Avería:</label>
                        <input type="text" id="descripcion_averia" name="descripcion_averia" required>
                        <small class="help-text">Detalla el daño (ej: empaque roto).</small>
                    </div>

                    <div class="form-group">
                        <label for="fecha_averia" data-i18n="averias:damage_date_label">Fecha:</label>
                        <input type="date" id="fecha_averia" name="fecha_averia" required>
                        <small class="help-text">Selecciona la fecha del reporte.</small>
                    </div>

                    <div class="form-group">
                        <label for="estado_averia" data-i18n="averias:status_label">Estado:</label>
                        <select id="estado_averia" name="estado" required>
                            <option value="Pendiente" data-i18n="averias:status_pending">Pendiente</option>
                            <option value="En Revisión" data-i18n="averias:status_in_review">En Revisión</option>
                            <option value="Descartado" data-i18n="averias:status_discarded">Descartado</option>
                        </select>
                        <small class="help-text">Estado actual del proceso.</small>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" class="bg-gray-500 hover:bg-gray-600 text-white font-bold py-3 px-6 rounded-lg transition" id="btn-limpiar-averia">
                        <i class="fas fa-trash mr-2"></i> Limpiar Formulario
                    </button>
                    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-8 rounded-lg transition">
                        Reportar Avería
                    </button>
                </div>
            </form>
        </div>
    </main>

    <script>
        function actualizarReloj() {
            const ahora = new Date();
            const opciones = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false };
            const textoFinal = ahora.toLocaleDateString('es-ES', opciones).replace(',', '');
            document.getElementById('reloj-vivo').innerText = textoFinal;
        }
        actualizarReloj();
        setInterval(actualizarReloj, 1000);
    </script>

</body>
</html>